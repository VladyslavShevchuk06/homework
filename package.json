{
  "name": "f1-catalog",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "format": "yarn type-check && yarn lint --fix && prettier --write \"src/**/*.{ts,tsx,json,md}\"",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "seed": "tsx --env-file=.env.local src/db/seed.ts",
    "dev:e2e": "dotenv -e .env.test.local -- next dev -p 3100",
    "start:e2e": "dotenv -e .env.test.local -- next start -p 3100",
    "db:migrate:test": "tsx --env-file=.env.test.local test/e2e/scripts/check-test-db.ts && cross-env DRIZZLE_ENV_FILE=.env.test.local drizzle-kit migrate",
    "seed:test": "tsx --env-file=.env.test.local test/e2e/scripts/check-test-db.ts && tsx --env-file=.env.test.local src/db/seed.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.3.4",
    "@t3-oss/env-nextjs": "^0.9.2",
    "@tanstack/react-query": "^5.42.0",
    "better-auth": "1.6.19",
    "clsx": "^2.1.0",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.9",
    "next-intl": "^4.13.1",
    "next-themes": "^0.4.6",
    "postgres": "^3.4.3",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-hook-form": "^7.50.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.3.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tanstack/react-query-devtools": "^5.101.2",
    "@types/node": "22.5.0",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "autoprefixer": "10.4.20",
    "cross-env": "^10.1.0",
    "dotenv": "^16.4.5",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "9.11.0",
    "eslint-config-next": "16.2.9",
    "postcss": "8.4.47",
    "prettier": "3.3.3",
    "tailwindcss": "3.4.1",
    "tsx": "4.17.0",
    "typescript": "5.6.2"
  }
}
